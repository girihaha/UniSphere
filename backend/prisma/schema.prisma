generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id
  name               String
  email              String              @unique
  password           String
  branch             String
  year               Int
  role               String              @default("student")
  avatarUrl          String?
  bio                String?
  posts              Int                 @default(0)
  createdAt          DateTime            @default(now())
  regNumber          String?
  clubAdmins         ClubAdmin[]
  clubFollowers      ClubFollower[]
  sentRequests       ConnectionRequest[] @relation("RequestSender")
  receivedRequests   ConnectionRequest[] @relation("RequestReceiver")
  networkNotes       NetworkNote[]
  notificationTarget Notification[]      @relation("NotificationTarget")
  authoredPosts      Post[]              @relation("PostAuthor")
  postComments       PostComment[]
  postLikes          PostLike[]
  postSaves          PostSave[]
  socialLinks        SocialLink[]
}

model SocialLink {
  id     Int     @id @default(autoincrement())
  userId String
  type   String
  handle String
  url    String?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Club {
  id              Int            @id @default(autoincrement())
  name            String
  avatar          String?
  createdAt       DateTime       @default(now())
  category        String
  coverImage      String?
  createdBy       String?
  description     String
  followers       Int            @default(0)
  isOfficial      Boolean        @default(false)
  members         Int            @default(0)
  status          String         @default("active")
  username        String         @unique
  verified        Boolean        @default(false)
  admins          ClubAdmin[]
  followerRecords ClubFollower[]
  tags            ClubTag[]
  posts           Post[]
}

model ClubTag {
  id     Int    @id @default(autoincrement())
  clubId Int
  value  String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubAdmin {
  id     Int    @id @default(autoincrement())
  clubId Int
  userId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model ClubFollower {
  id     Int    @id @default(autoincrement())
  clubId Int
  userId String
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model Post {
  id              Int           @id @default(autoincrement())
  title           String
  content         String
  type            String
  kind            String
  authorId        String
  clubId          Int?
  status          String
  createdAt       DateTime      @default(now())
  adminReviewedAt String?
  adminReviewedBy String?
  author          String
  authorName      String
  authorRole      String
  authorType      String
  avatar          String?
  clubAvatar      String?
  clubName        String?
  clubReviewedAt  String?
  clubReviewedBy  String?
  eventDate       String?
  eventLocation   String?
  eventTime       String?
  image           String?
  registerLink    String?
  rejectionReason String?
  submittedAt     String
  summary         String?
  userAvatar      String?
  authorUser      User          @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  club            Club?         @relation(fields: [clubId], references: [id])
  comments        PostComment[]
  likes           PostLike[]
  saves           PostSave[]
}

model PostLike {
  id     Int    @id @default(autoincrement())
  postId Int
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostSave {
  id     Int    @id @default(autoincrement())
  postId Int
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id           Int      @id @default(autoincrement())
  postId       Int
  authorId     String
  authorName   String
  authorAvatar String?
  text         String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ConnectionRequest {
  id         Int      @id @default(autoincrement())
  fromUserId String
  toUserId   String
  message    String?
  createdAt  DateTime @default(now())
  fromUser   User     @relation("RequestSender", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("RequestReceiver", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

model NetworkConnection {
  id        Int      @id @default(autoincrement())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
}

model NetworkNote {
  id        Int      @id @default(autoincrement())
  authorId  String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      String
  type        String
  message     String
  actorId     String
  actorName   String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  actionState String?
  actorRole   String?
  postId      Int?
  postTitle   String?
  timestamp   String   @default("Just now")
  timestampMs BigInt
  user        User     @relation("NotificationTarget", fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetOtp {
  id         Int       @id @default(autoincrement())
  email      String
  otpHash    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

model PendingSignup {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  regNumber String?
  branch    String
  year      Int
  role      String   @default("student")
  otpHash   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
